# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/skillmatch

# JWT
JWT_SECRET=replace_with_long_random_secret_min_32_chars
JWT_EXPIRE=7d

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS & email links)
CLIENT_URL=http://localhost:3000

# Google OAuth (optional - leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Anthropic AI - Claude — NOT USED anymore. All "AI" features (resume
# analyzer, cover letter generator, interview questions, skill suggestions)
# now run on free built-in algorithms, no key or subscription needed.
# This var is kept only in case you want to wire Claude back in later.
ANTHROPIC_API_KEY=

# Email notifications
# Option A — Gmail (leave SMTP_HOST blank): create an App Password at
#   myaccount.google.com → Security → 2FA → App Passwords
# Option B — Any SMTP provider (Hostinger, Zoho, Brevo, Mailtrap, etc.):
#   set SMTP_HOST/SMTP_PORT/SMTP_SECURE below and EMAIL_USER/EMAIL_PASS
#   to that provider's credentials.
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password_or_app_password

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false

# Session
SESSION_SECRET=replace_with_random_session_secret
